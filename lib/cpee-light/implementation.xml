<description datatypeLibrary="http://www.w3.org/2001/XMLSchema-datatypes" xmlns="http://riddl.org/ns/description/1.0" xmlns:xi="http://www.w3.org/2001/XInclude">
  <message name="one">
    <parameter name="mode" fixed="one"/>
  </message>
  <message name="continuous">
    <parameter name="mode" fixed="continuous"/>
  </message>
  <message name="lumens">
    <parameter name="lumens" type="float"/>
  </message>
  <message name="intensity">
    <parameter name="intensity" type="integer">
      <param name="minInclusive">0</param>
      <param name="maxInclusive">100</param>
    </parameter>
  </message>
  <message name="state">
    <parameter name="state" type="string">
      <choice>
        <value>on</value>
        <value>off</value>
      </choice>
    </parameter>
  </message>

  <resource>
    <resource relative="light">
      <put in="intensity"/>
      <resource relative="\d+">
        <put in="state"/>
      </resource>
    </resource>
    <resource relative="sensor">
      <get in="one" out="lumens"/>
      <get in="continuous" out="lumens"/>
    </resource>
  </resource>

</description>
